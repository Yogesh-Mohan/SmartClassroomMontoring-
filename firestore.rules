rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && (
            exists(/databases/$(database)/documents/admins/$(request.auth.uid))
            || (
              request.auth.token.email != null
              && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
            )
            || (
              request.auth.token.customClaims != null
              && request.auth.token.customClaims.isAdmin == true
            )
            || (
              request.auth.token.customClaims != null
              && request.auth.token.customClaims.role in ['admin', 'Admin', 'ADMIN', 'administrator', 'Administrator']
            )
          );
    }

    function isAdvisor() {
      return request.auth != null
          && (
            request.auth.token.customClaims != null
            && (
              request.auth.token.customClaims.isAdvisor == true
              || request.auth.token.customClaims.role in ['advisor', 'Advisor', 'ADVISOR']
            )
          );
    }

    function isStaff() {
      return isAdmin() || isAdvisor();
    }

    function isTaskCreator(taskId) {
      return request.auth != null
          && exists(/databases/$(database)/documents/tasks/$(taskId))
          && get(/databases/$(database)/documents/tasks/$(taskId)).data.createdByUID == request.auth.uid;
    }

    // ── STUDENTS ──────────────────────────────────────────────────────────────
    // Any authenticated user can read (needed for login flow to fetch profile).
    // Only the matching student (by uid) can update their own doc.
    // No one can create/delete from the app.
    match /students/{docId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.uid || isStaff());
      allow create: if isStaff();
      allow delete: if false;
    }

    // ── ADMINS ────────────────────────────────────────────────────────────────
    match /admins/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == docId;
      allow delete: if false;
    }

    // ── USERS (role mapping) ────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // ── STUDENT SESSIONS (login state / heartbeat) ───────────────────────────
    // Students write their own session doc (docId = their UID).
    // Admins can read all session docs for the live dashboard.
    match /student_sessions/{docId} {
      allow read: if request.auth != null
                  && (request.auth.uid == docId || isAdmin());
      allow create, update: if request.auth != null
                            && (request.auth.uid == docId || isAdmin());
      allow delete: if false;
    }

    // ── DEVICES ───────────────────────────────────────────────────────────────
    // Authenticated users can read device/sensor data; IoT devices write via
    // server-side admin SDK (not affected by client rules).
    match /devices/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── SCHEDULE & TIMETABLES ─────────────────────────────────────────────────
    match /schedule/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Timetables — recursive wildcard covers the top-level doc AND
    // every subcollection at any depth (e.g. wednesday/peroid 0).
    match /timetables/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── VIOLATIONS ────────────────────────────────────────────────────────────
    // Authenticated students can create their own violation docs.
    // Only the student who owns it (or admin) can read.
    match /violations/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.studentUID == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.studentUID == request.auth.uid
                    && request.resource.data.studentUID == resource.data.studentUID;
      allow delete: if false;
    }

    // ── ALERTS ───────────────────────────────────────────────────────────────
    // Student app writes alert delivery result (FCM/SMS status).
    // Admin can read for monitoring dashboards.
    match /alerts/{docId} {
      allow read: if request.auth != null
                  && (isAdmin() || resource.data.studentUID == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.studentUID == request.auth.uid;
      allow update, delete: if false;
    }

    // ── ATTENDANCE ────────────────────────────────────────────────────────────
    // Admin can read ALL attendance docs (required for collection list queries).
    // Student can read/update only their own doc (for logoutTime).
    // Student can create their own attendance doc (docId = uid_YYYY_MM_DD).
    match /attendance/{docId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.studentUID == request.auth.uid);
      allow update: if request.auth != null
                    && resource.data.studentUID == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.studentUID == request.auth.uid;
      allow delete: if false;
    }

    // ── SMART ATTENDANCE SESSIONS ───────────────────────────────────────────
    match /attendance_sessions/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isAdmin();
      allow delete: if false;
    }

    // ── SMART ATTENDANCE RECORDS ───────────────────────────────────────────
    match /attendance_records/{docId} {
      // Non-existing doc reads are used by duplicate-check flow before create.
      allow read: if request.auth != null
                  && (
                    isAdmin()
                    || !exists(/databases/$(database)/documents/attendance_records/$(docId))
                    || resource.data.studentUID == request.auth.uid
                  );

      // Students can create their own attendance (manual==false, status==present).
      // Admins can create any record (manual overrides, batch submissions).
      allow create: if request.auth != null
                    && (
                      isAdmin()
                      || (
                        request.resource.data.studentUID == request.auth.uid
                        && request.resource.data.status == 'present'
                        && request.resource.data.manual == false
                      )
                    );

      allow update: if request.auth != null
                    && (
                      isAdmin()
                      || (
                        resource.data.studentUID == request.auth.uid
                        && request.resource.data.studentUID == request.auth.uid
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.manual == resource.data.manual
                      )
                    );
      allow delete: if false;
    }

    // ── CLASSROOM GEOFENCES ─────────────────────────────────────────────────
    match /classroom_geofences/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // ── LOGOUT ATTEMPTS ───────────────────────────────────────────────────────
    // Any authenticated user (student) can create early-logout attempt records.
    // Admin can read all logout_attempts docs.
    // No update/delete from client.
    match /logout_attempts/{docId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null
                    && isAdmin();
      allow update, delete: if false;
    }

    // ── FCM TOKENS ───────────────────────────────────────────────────────────
    match /fcmTokens/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── FOCUS SUMMARY ─────────────────────────────────────────────────────────
    // Students can read their own focus_summary doc (docId = their UID).
    // Admins can read all focus_summary docs.
    // Only server/admin SDK can write.
    match /focus_summary/{docId} {
      allow read: if request.auth != null
                  && (request.auth.uid == docId
                      || isAdmin());
      allow write: if false;
    }

    // ── TASKS & SUBMISSIONS ──────────────────────────────────────────────────
    // Students must read tasks/submissions for Alerts + Home sections.
    // Admin creates tasks/reviews submissions.
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();

      match /submissions/{studentUid} {
        allow read: if request.auth != null
                    && (request.auth.uid == studentUid || isStaff() || isTaskCreator(taskId));
        allow create, update: if request.auth != null
                              && (
                                (request.auth.uid == studentUid
                                  && request.resource.data.studentUID == request.auth.uid)
                                || isStaff()
                                || isTaskCreator(taskId)
                              );
        allow delete: if isAdmin();
      }
    }

    // ── CREDITS MODULE ───────────────────────────────────────────────────────
    // Students can submit/read own certificates and own marks; advisors/admins manage approvals.
    match /certificates/{docId} {
      allow read: if request.auth != null
                  && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if request.auth != null
                    && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // ── STUDENT ALERTS ──────────────────────────────────────────────────────
    match /student_alerts/{docId} {
      allow read: if request.auth != null
                  && (
                    isStaff()
                    || request.auth.uid in resource.data.recipientKeys
                    || (
                      request.auth.token.email != null
                      && request.auth.token.email in resource.data.recipientKeys
                    )
                  );
      allow create, update, delete: if isStaff();
    }

    match /interactionScores/{docId} {
      allow read: if request.auth != null
                  && (resource.data.studentUid == request.auth.uid
                      || isAdmin()
                      || isAdvisor());
      allow write: if isAdmin() || isAdvisor();
    }

    match /internalMarks/{docId} {
      allow read: if request.auth != null
                  && (resource.data.studentUid == request.auth.uid
                      || isAdmin()
                      || isAdvisor());
      allow write: if isAdmin() || isAdvisor();
    }

    // ── LIVE MONITORING ───────────────────────────────────────────────────────
    // Students write their own real-time monitoring data (docId = their UID).
    // Admins can read all live monitoring data for the dashboard.
    match /live_monitoring/{docId} {
      allow read: if request.auth != null
                  && (request.auth.uid == docId || isAdmin());
      allow create, update: if request.auth != null
                            && request.auth.uid == docId;
      allow delete: if false;
    }

    // ── MONITORING SETTINGS (Admin master switch) ─────────────────────────────
    // Admin writes monitoringEnabled toggle.
    // All authenticated users (including students) can read so they can
    // react to the admin switch in real-time.
    match /monitoring_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── CLASSROOM METRICS (ML live student count) ───────────────────────────
    // Backend Admin SDK writes are server-side. Admin app needs read access
    // to render Live Camera Count on attendance screen.
    match /classroom_metrics/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }

    // ── BLOCK EVERYTHING ELSE ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
